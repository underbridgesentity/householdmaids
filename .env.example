# ----------------------------------------------------------------------------
# Household Maids — environment template. Copy to `.env` and fill real values.
# NEVER commit the real `.env`.
# ----------------------------------------------------------------------------

# Database (Postgres). For local dev, `npm run db:up` starts the docker-compose DB.
DATABASE_URL="postgresql://hhm:hhm@localhost:5433/household_maids?schema=public"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-generate-a-32-byte-base64-secret"
AUTH_TRUST_HOST="true"

# App-level encryption key for PII (ID numbers, bank details).
# 32 bytes, base64. Generate with: openssl rand -base64 32
ENCRYPTION_KEY="change-me-generate-a-32-byte-base64-secret"

# Public base URL (used for Payfast return/cancel/notify URLs).
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ---- Payfast (https://developers.payfast.co.za) ----
# Use sandbox credentials in dev. PAYFAST_SANDBOX=true points at sandbox.payfast.co.za.
PAYFAST_MERCHANT_ID="10000100"
PAYFAST_MERCHANT_KEY="46f0cd694581a"
PAYFAST_PASSPHRASE=""
PAYFAST_SANDBOX="true"
