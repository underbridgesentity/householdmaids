# ----------------------------------------------------------------------------
# Household Maids — environment template. Copy to `.env` and fill real values.
# NEVER commit the real `.env`.
# ----------------------------------------------------------------------------

# Database (Postgres). For local dev, `npm run db:up` starts the docker-compose DB.
DATABASE_URL="postgresql://hhm:hhm@localhost:5433/household_maids?schema=public"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="change-me-generate-a-32-byte-base64-secret"
AUTH_TRUST_HOST="true"

# App-level encryption key for PII (ID numbers, bank details).
# 32 bytes, base64. Generate with: openssl rand -base64 32
ENCRYPTION_KEY="change-me-generate-a-32-byte-base64-secret"

# Public base URL (used for Payfast return/cancel/notify URLs).
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ---- Payfast (https://developers.payfast.co.za) ----
# Use sandbox credentials in dev. PAYFAST_SANDBOX=true points at sandbox.payfast.co.za.
PAYFAST_MERCHANT_ID="10000100"
PAYFAST_MERCHANT_KEY="46f0cd694581a"
PAYFAST_PASSPHRASE=""
PAYFAST_SANDBOX="true"

# ---- Optional production adapters (each falls back safely if unset) ----
# Rate limiting across serverless instances (https://upstash.com — free tier).
# Without these, an in-memory limiter is used (fine for a single instance / dev).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Transactional email (password reset, notifications). Without SMTP_HOST, emails
# are logged to the dev console instead of being sent.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Household Maids <no-reply@householdmaids.co.za>"

# Helper document storage. With a Vercel Blob token, encrypted ID/selfie files
# are stored in Blob (works on serverless). Without it, they go to a local
# ./storage dir (dev only — not persistent on Vercel). Add Blob storage in the
# Vercel dashboard to auto-inject this token.
BLOB_READ_WRITE_TOKEN=""
